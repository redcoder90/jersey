rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsSession() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnPendingSession() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending_verification'
        && request.resource.data.verificationCompleted == false
        && !('verifiedAt' in request.resource.data)
        && !('completedAt' in request.resource.data);
    }

    function verifiesPendingSessionOnly() {
      return ownsSession()
        && resource.data.status == 'pending_verification'
        && resource.data.verificationCompleted == false
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'verificationCompleted', 'verifiedAt'])
        && request.resource.data.status == 'verified'
        && request.resource.data.verificationCompleted == true
        && ('verifiedAt' in request.resource.data);
    }

    function completesVerifiedSessionOnly() {
      return ownsSession()
        && resource.data.status == 'verified'
        && resource.data.verificationCompleted == true
        && ('verifiedAt' in resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'completedAt'])
        && request.resource.data.status == 'completed';
    }

    match /payment_sessions/{sessionId} {
      allow create: if createsOwnPendingSession();
      allow read: if ownsSession();
      allow update: if verifiesPendingSessionOnly()
        || completesVerifiedSessionOnly();
      allow delete: if false;
    }

    match /otp_verifications/{otpId} {
      function validOtpRecord() {
        return request.resource.data.keys().hasOnly([
            'email',
            'otp',
            'purpose',
            'createdAt',
            'expiresAt',
            'attempts',
            'verified',
          ])
          && request.resource.data.email is string
          && request.resource.data.otp is string
          && request.resource.data.otp.matches('^[0-9]{6}$')
          && request.resource.data.purpose in ['signup', 'payment']
          && request.resource.data.createdAt is timestamp
          && request.resource.data.expiresAt is timestamp
          && request.resource.data.attempts is int
          && request.resource.data.attempts >= 0
          && request.resource.data.attempts <= 5
          && request.resource.data.verified is bool;
      }

      allow create: if validOtpRecord()
        && request.resource.data.attempts == 0
        && request.resource.data.verified == false;
      allow read: if true;
      allow update: if validOtpRecord()
        && resource.data.email == request.resource.data.email
        && resource.data.purpose == request.resource.data.purpose;
      allow delete: if signedIn();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;

      match /cart/{itemId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /wishlist/{itemId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /orders/{orderId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
